{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/statusline"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "mcpServers": {
    "chrome-devtools": {
      "type": "sse",
      "url": "http://chrome-devtools-mcp:8100/sse"
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(npm)",
      "Bash(npm *)",
      "Bash(npx *)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/claude/.claude/hooks/workspace-repo-audit.sh",
            "timeout": 180,
            "statusMessage": "Auditing /workspace git repos (branch + behind main)..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/claude/.claude/hooks/block-lockfile-edits.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/claude/.claude/hooks/guard-bash-commands.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/claude/.claude/hooks/select-repo-instructions.sh"
          }
        ]
      }
    ]
  }
}
