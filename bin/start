#!/bin/bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
source $SCRIPT_DIR/lib

export GITHUB_TOKEN=$(get-keychain-secret $CLAUDE_TOKEN_SECRET_NAME)
export DD_API_KEY=$(get-keychain-secret $DATADOG_API_KEY_SECRET_NAME)
export DD_APP_KEY=$(get-keychain-secret $DATADOG_APP_KEY_SECRET_NAME)

docker compose run --rm -e GITHUB_TOKEN -e DD_API_KEY -e DD_APP_KEY claude
