#!/bin/bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
source $SCRIPT_DIR/lib

cd "$SCRIPT_DIR/../"

export GITHUB_TOKEN=$(get-keychain-secret $GITHUB_TOKEN)
export GITHUB_TOKEN_EXTRAS=$(get-keychain-secret $GITHUB_TOKEN_EXTRAS)
export GITHUB_PACKAGES_TOKEN=$(get-keychain-secret $GITHUB_PACKAGES_TOKEN)
export DD_API_KEY=$(get-keychain-secret $DATADOG_API_KEY_SECRET_NAME)
export DD_APP_KEY=$(get-keychain-secret $DATADOG_APP_KEY_SECRET_NAME)

if [ -z "$(docker compose ps -q socat)" ]; then
  echo "Socat is NOT running, starting it."
  docker compose up -d socat
fi

if [ -z "$(docker compose ps -q claude)" ]; then
  echo "Claude container is NOT running, starting it."
  docker compose up -d claude
fi

docker compose exec claude herdr
