#!/bin/bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
source $SCRIPT_DIR/lib

cd "$SCRIPT_DIR/../"

export GITHUB_TOKEN=$(get-keychain-secret $GITHUB_TOKEN)
export GITHUB_PACKAGES_TOKEN=$(get-keychain-secret $GITHUB_PACKAGES_TOKEN)
export DD_API_KEY=$(get-keychain-secret $DATADOG_API_KEY_SECRET_NAME)
export DD_APP_KEY=$(get-keychain-secret $DATADOG_APP_KEY_SECRET_NAME)

docker compose run --rm -e GITHUB_TOKEN -e GITHUB_PACKAGES_TOKEN -e DD_API_KEY -e DD_APP_KEY claude
