#!/usr/bin/env bash
# Git credential helper: route github.com auth to the correct token by org.
#
# smile-io lives under the primary $GITHUB_TOKEN; smile-io-extras (e.g.
# smile-agents) is a separate org the primary token cannot reach and needs
# $GITHUB_TOKEN_EXTRAS. Git alone cannot pick a token per-org, so this helper
# reads the requested path and returns the right one.
#
# Wired in ~/.gitconfig under [credential "https://github.com"] with
# useHttpPath = true, so git passes the org as the leading path segment.
# SSH-form remotes reach here via the url.insteadOf rewrite to https.
set -euo pipefail

# git invokes the helper with the operation as $1 (get|store|erase). Only
# `get` returns credentials; store/erase are no-ops (tokens come from the
# environment, nothing to persist or clear).
[ "${1:-}" = get ] || exit 0

path=
while IFS='=' read -r key value; do
  [ "$key" = path ] && path="$value"
done

echo "username=x-access-token"
case "$path" in
  smile-io-extras/*) echo "password=${GITHUB_TOKEN_EXTRAS}" ;;
  *)                 echo "password=${GITHUB_TOKEN}" ;;
esac
